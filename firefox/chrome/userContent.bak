	/* Change image file icon */
	img[src^="moz-icon://.png"],
	img[src^="moz-icon://.jpg"],
	img[src^="moz-icon://.jpeg"],
	img[src^="moz-icon://.svg"] {
		background: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"><path xmlns="http://www.w3.org/2000/svg" fill-rule="evenodd" clip-rule="evenodd" d="M1 1H15V15H1V1ZM6 9L8 11L13 6V13H3V12L6 9ZM6.5 7C7.32843 7 8 6.32843 8 5.5C8 4.67157 7.32843 4 6.5 4C5.67157 4 5 4.67157 5 5.5C5 6.32843 5.67157 7 6.5 7Z" /></svg>') !important;
	}

	/* Change XCF (GIMP) file icon */
	img[src^="moz-icon://.xcf"] {
		background: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 128 128" xmlns="http://www.w3.org/2000/svg"><path d="m 29.09375,11.234375 c -3.1838,0 -5.71875,2.5662 -5.71875,5.75 l 0,94.031255 c 0,3.1838 2.53495,5.75 5.71875,5.75 l 69.8125,0 c 3.18379,0 5.71875,-2.5662 5.71875,-5.75 l 0,-70.656255 -21.03125,0 c -4.30611,0 -8.0625,-3.14111 -8.0625,-7.3125 l 0,-21.8125 -46.4375,0 z m 50.4375,0 0,21.8125 c 0,1.71413 1.63197,3.3125 4.0625,3.3125 l 21.03125,0 -25.09375,-25.125 z m 12.375,44.34375 c 0.40462,0 1.35235,10.08638 -1.40625,15.28125 -2.52382,4.75272 -7.5625,8.5625 -7.5625,8.5625 0,0 -0.73639,2.80156 -2,5.75 -1.26362,2.94844 -4.04107,7.15982 -10.21875,9.40625 -6.17768,2.24644 -17.14932,1.29399 -22.625,-0.53125 -3.1398,-1.04659 -4.43676,-2.3737 -4.96875,-3.3125 -0.61932,0.32065 -1.26517,0.46875 -1.96875,0.46875 -3.0629,0 -5.5625,-3.29653 -5.5625,-7.40625 0,-4.10971 2.4996,-7.4375 5.5625,-7.4375 1.7187,0 3.264,1.00936 4.28125,2.65625 1.83117,-2.87061 4.64683,-6.10698 6.71875,-7.875 -4.53574,-3.39891 -4.45059,-8.17082 -5.46875,-12.625 8.60651,8.62516 13.44501,13.01979 21.8125,12.6875 10.00982,-0.3975 17.41535,-3.24695 23.40625,-15.625 z" /></svg>') !important;

		height: 18px !important;
		padding-left: 18px !important;
		background-size: 18px 18px !important;

		position: relative !important;
		left: 2px !important;
	}

	body:has(#UI_showHidden, #UI_goUp) td:has(img[src^="moz-icon://.xcf"]) {
		position: relative !important;
		left: -2px !important;
	}

	/* Change TEX file icon */
	img[src^="moz-icon://.tex"] {
		background: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><path d="M11.333,13.122c-.128-1.562-.241-2.756-2.287-2.756H7.91v8.4h2.145v.611l-3.083-.029-3.082.029v-.611H6.034v-8.4H4.884c-2.046,0-2.159,1.208-2.287,2.756H2l.284-3.367h9.362l.284,3.367h-.6Z"/><path d="M19.289,22.53H10.41V21.92h1.506V13.467H10.41v-.611h8.637l.412,3.367h-.6c-.213-1.833-.682-2.756-2.855-2.756H13.791V17.2h.838c1.364,0,1.505-.6,1.505-1.662h.6v3.935h-.6c0-1.08-.142-1.662-1.505-1.662h-.838v4.106h2.216c2.472,0,3-1.108,3.3-3.225h.6Z"/><path d="M27.727,19.186c-.54,0-1.96,0-2.415.029V18.6h1.179l-2.557-3.552-2.529,3.381A4.1,4.1,0,0,0,22.7,18.6v.611c-.355-.029-1.576-.029-2.017-.029-.4,0-1.548,0-1.875.029V18.6h.383a7.459,7.459,0,0,0,.824-.043c.5-.043.54-.085.667-.256L23.536,14.5l-3.153-4.418H19V9.47c.384.028,1.79.028,2.273.028.582,0,1.918,0,2.429-.028v.611H22.528l2.117,2.955,2.074-2.784a4.1,4.1,0,0,0-1.293-.17V9.47c.356.028,1.591.028,2.032.028.4,0,1.534,0,1.861-.028v.611h-.369a5.264,5.264,0,0,0-.838.043c-.469.043-.526.071-.667.256l-2.4,3.21L28.636,18.6H30v.611C29.645,19.186,28.182,19.186,27.727,19.186Z" /></svg>') !important;
	}

	/* Change archive file icon */
	img[src^="moz-icon://.zip"] {
		height: 16px !important;
		padding-left: 16px !important;
		background-size: 16px 16px !important;

		background: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M426.666667 170.666667H170.666667c-47.146667 0-84.906667 38.186667-84.906667 85.333333L85.333333 768c0 47.146667 38.186667 85.333333 85.333334 85.333333h682.666666c47.146667 0 85.333333-38.186667 85.333334-85.333333V341.333333c0-47.146667-38.186667-85.333333-85.333334-85.333333H512l-85.333333-85.333333z M680 320h90v50h-90v-50zm70 50h90v50h-90v-50zm-70 50h90v50h-90v-50zm70 50h90v50h-90v-50zm-70 50h90v50h-90v-50zm70 50h90v50h-90v-50zm-70 50h90v50h-90v-50zm70 50h90v50h-90v-50zm-70 50h90v50h-90v-50z" /></svg>') !important;

		position: relative !important;
		left: 1px !important;
	}

	body:has(#UI_showHidden, #UI_goUp) td:has(img[src^="moz-icon://.zip"]) {
		position: relative !important;
		left: -1px !important;
	}

	/* Change video file icon */
	img[src^="moz-icon://.mp4"],
	img[src^="moz-icon://.mov"],
	img[src^="moz-icon://.webm"],
	img[src^="moz-icon://.mkv"] {
		background: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M16 2H0V14H16V2ZM6.5 5V11H7.5L11 8L7.5 5H6.5Z" /></svg>') !important;
	}

