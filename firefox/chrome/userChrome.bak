/* Last working version: Mozilla Firefox 152.0 */

@import "fonts.css";

@-moz-document url-prefix("chrome://") {

:root {
	/* Colors */
	--bg-color: #111111;
	--lighter-bg-color: #1A1A1A;
	--lightest-bg-color: #2A2A2A;
	--fg-color: __FG__;
	--accent-color: __COL1__;

	/* Panel customization */
	--panel-background: var(--lighter-bg-color) !important;
	--panel-border-color: var(--bg-color) !important;
	--panel-color: #ffffff !important;

	/* Toolbar button customization */
	--toolbarbutton-hover-background: transparent !important;
	--toolbarbutton-active-background: transparent !important;
	--toolbarbutton-active-outline-color: var(--accent-color) !important;
	--toolbarbutton-icon-fill-attention: var(--accent-color) !important;

	--color-accent-primary: var(--accent-color) !important;
	--border-color-selected: var(--accent-color) !important;

	/* Customize links */
	--link-color: var(--accent-color) !important;
	--link-color-hover: var(--accent-color) !important;
	--link-color-active: var(--accent-color) !important;

	/* Other fixes */
	--text-color: var(--fg-color) !important;
	--focus-outline-color: var(--accent-color) !important;
	--toolbar-bgcolor: var(--bg-color) !important;
	--toolbar-color: var(--fg-color) !important;
	--info-bar-text-color: var(--fg-color) !important;
	--info-bar-background-color: var(--accent-color) !important;
}

/* Change font and accent color on all elements */
* {
	font-family: "JetBrainsMono NF" !important;
	accent-color: var(--accent-color) !important;
}

/* Change popup colors */
menupopup, panel {
	--panel-background-color: var(--lighter-bg-color) !important;
	--panel-border-color: var(--bg-color) !important;
	--panel-text-color: var(--fg-color) !important;
}

menuitem[_moz-menuactive="true"] {
	background-color: var(--accent-color) !important;
}

#select-translations-panel-text-area {
	outline: none !important;
	border-color: var(--accent-color) !important;
}

/* Style infobar */
.infobar {
	--info-bar-background-color: var(--lighter-bg-color) !important;
	--info-bar-text-color: var(--fg-color) !important;

	background-color: var(--lighter-bg-color) !important;
	color: var(--fg-color) !important;
}

.infobar::before {
	background: none !important;
}

.icon-container .icon {
	color: var(--accent-color) !important;
}

/* Change color of close browser confirmation popup */
window#commonDialogWindow {
	background-color: var(--lighter-bg-color) !important;
}

/* Customize buttons */
button[default="true"], button.primary {
	border: 2px solid var(--accent-color) !important;
	color: var(--fg-color) !important;
	background: none !important;
}

.toggle-button[aria-pressed="true"] {
	background: none !important;
	border: 1px solid var(--accent-color) !important;

	&::before {
		background-color: var(--accent-color) !important;
	}
}

/* Customize some links (--link-color in :root should be enough but just in case) */
.panel-subview-footer-button {
	color: var(--accent-color) !important;
}

/* Hide all tabs button */
toolbarbutton#alltabs-button {
	display: none !important;
}

/* Hide tab scroll forwards and backwards buttons */
toolbarbutton#scrollbutton-down {
	display: none !important;
}

toolbarbutton#scrollbutton-up .toolbarbutton-icon {
	width: 0px !important;
}

/* Hide browser close button */
toolbarbutton.titlebar-button.titlebar-close {
	display: none !important;
}

/* Hide reader mode button */
#reader-mode-button {
	display: none !important;
}

/* Hide picture-in-picture button */
#picture-in-picture-button {
	display: none !important;
}

/* Move tabs below address bar */
toolbar#TabsToolbar {
	order: 2 !important;
}

/* Bookmark bar customizaton */
toolbar#PersonalToolbar {
	/* Move bookmarks below tabs */
	order: 3 !important;

	height: 32px !important;

	/* Change bookmark toolbar colors */
	background-color: var(--bg-color) !important;
	color: var(--fg-color) !important;
	font-weight: 500 !important;

	/* Only show bookmarks when hovered over */
	opacity: 0 !important;
	max-height: 0px !important;
	transition:
		opacity 0.3s ease 1s,
		max-height 0.3s ease 1s !important;
}

toolbar#TabsToolbar:hover ~ toolbar#PersonalToolbar,
toolbar#PersonalToolbar:hover {
	opacity: 1 !important;
	max-height: 100px !important;
	transition:
		opacity 0.3s ease 1s,
		max-height 0.3s linear 1s !important;
}

/* Change color of menu bookmark item */
image.toolbarbutton-icon[type="menu"] {
	fill: var(--fg-color) !important;
}

/* Change colors of active or opened bookmark item (ex.: folder) */
toolbarbutton.bookmark-item[open="true"],
toolbarbutton.bookmark-item:active {
	color: var(--accent-color) !important;
	border-radius: 4px !important;
	font-weight: 700 !important;
}

toolbarbutton.bookmark-item[open="true"] image.toolbarbutton-icon[type="menu"] {
	fill: var(--accent-color) !important;
}

/* Change icon of directory */
image.toolbarbutton-icon[src^="page-icon:file:///"] {
	-moz-context-properties: fill !important;
	fill: var(--fg-color) !important;
	content: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg"><path d="M426.666667 170.666667H170.666667c-47.146667 0-84.906667 38.186667-84.906667 85.333333L85.333333 768c0 47.146667 38.186667 85.333333 85.333334 85.333333h682.666666c47.146667 0 85.333333-38.186667 85.333334-85.333333V341.333333c0-47.146667-38.186667-85.333333-85.333334-85.333333H512l-85.333333-85.333333z" /></svg>') !important;
	width: 18px !important;
	height: 18px !important;
}

/* Add more space between bookmark icon and label */
toolbarbutton.bookmark-item image.toolbarbutton-icon {
	margin-inline-end: 6px !important;
}

/* Improve bookmark icon vertical alignment */
toolbarbutton.bookmark-item image.toolbarbutton-icon {
	margin-block-end: -2px !important;
}

/** Customize address bar **/

/* Change icon colors */
toolbarbutton#back-button,
toolbarbutton#forward-button,
toolbarbutton#reload-button,
toolbarbutton#PanelUI-menu-button,
toolbarbutton#downloads-button,
toolbarbutton#reset-pbm-toolbar-button,
#trust-icon,
#star-button,
#translations-button-icon,
#permissions-granted-icon,
.blocked-permission-icon,
#urlbar-revert-button {
	fill: var(--fg-color) !important;
}

.tab-throbber {
	color: var(--fg-color) !important;
}

.button-background {
	color: var(--fg-color) !important;
}

/* Change icon colors when open/active (burger menu, refresh, etc) */
#nav-bar .toolbarbutton-1[open="true"] > .toolbarbutton-badge-stack,
toolbarbutton#reset-pbm-toolbar-button:active .toolbarbutton-icon,
toolbarbutton#reset-pbm-toolbar-button[open="true"] .toolbarbutton-icon,
.toolbarbutton-animatable-box,
toolbarbutton#back-button:active .toolbarbutton-icon,
toolbarbutton#back-button[open="true"] .toolbarbutton-icon,
toolbarbutton#forward-button:active .toolbarbutton-icon,
toolbarbutton#forward-button[open="true"] .toolbarbutton-icon,
toolbarbutton#reload-button:active,
toolbarbutton#stop-button {
	fill: var(--accent-color) !important;
}

#translations-button-locale {
	background-color: var(--accent-color) !important;
}

#urlbar-revert-button:hover {
	background: none !important;
}

toolbarbutton#urlbar-zoom-button {
	color: var(--fg-color) !important;
}

/* Change downloads button color */
#downloads-indicator-icon {
	fill: var(--fg-color) !important;
}

toolbarbutton#downloads-button[attention] #downloads-indicator-icon,
toolbarbutton#downloads-button[downloading] #downloads-indicator-icon,
toolbarbutton#downloads-button[open="true"] #downloads-indicator-icon {
	fill: var(--accent-color) !important;
}

/* Download animations */
#downloads-indicator-finish-image,
#downloads-indicator-start-image,
#downloads-indicator-progress-inner,
#downloads-indicator-progress-outer {
	fill: var(--accent-color) !important;
}

/* Style normal/hover/active effects of trust icon, permissions box, translation icon, and bookmark icon */
#trust-icon-container,
#identity-permission-box,
#translations-button,
#star-button-box {
	background: none !important;
	outline: none !important;
	border: none !important;
}

#trust-icon-container[open="true"],
#trust-icon-container:active,
#identity-permission-box[open="true"],
#identity-permission-box:active,
#translations-button[open="true"],
#translations-button:active,
#star-button-box[open="true"],
#star-button-box:active {
	outline: 1px solid var(--accent-color) !important;
}

#trust-icon-container[open="true"] #trust-icon,
#trust-icon-container:active #trust-icon,
#identity-permission-box[open="true"] #permissions-granted-icon,
#identity-permission-box:active #permissions-granted-icon,
#identity-permission-box[open="true"] .blocked-permission-icon,
#identity-permission-box:active .blocked-permission-icon,
#translations-button[open="true"] #translations-button-icon,
#translations-button:active #translations-button-icon,
#star-button-box[open="true"] #star-button,
#star-button-box:active #star-button,
#star-button[starred] {
	fill: var(--accent-color) !important;
}

/* Hide other search engines button */
.searchmode-switcher {
	display: none !important;
}

/* Change icon of new tab */
.tab-icon-image[src="chrome://branding/content/icon32.png"] {
	-moz-context-properties: fill !important;
	fill: var(--fg-color) !important;
	content: url('data:image/svg+xml;utf8,<svg width="16px" height="16px" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><path fill="context-fill" d="M11.807 9.776c0.011 0 0.005 0 0 0zM8.109 7.927c0.011 0 0.005 0 0 0zM30.229 10.781c-0.667-1.604-2.021-3.333-3.079-3.885 0.865 1.692 1.365 3.396 1.552 4.661l0.005 0.027c-1.739-4.329-4.681-6.073-7.088-9.871-0.12-0.192-0.24-0.385-0.36-0.588-0.063-0.104-0.115-0.208-0.172-0.319-0.099-0.192-0.171-0.395-0.224-0.609 0-0.020-0.015-0.036-0.036-0.041-0.011 0-0.021 0-0.031 0l-0.005 0.005c-0.005 0-0.011 0.005-0.011 0.005s0-0.005 0.005-0.011c-3.417 2-4.828 5.505-5.193 7.729-1.057 0.063-2.088 0.328-3.041 0.776-0.183 0.093-0.265 0.303-0.197 0.489 0.077 0.213 0.317 0.319 0.525 0.224 0.833-0.391 1.729-0.625 2.651-0.687l0.089-0.011c0.125-0.005 0.255-0.011 0.38-0.011 0.745-0.005 1.489 0.099 2.203 0.307l0.125 0.037c0.12 0.036 0.235 0.077 0.355 0.12 0.083 0.031 0.172 0.063 0.255 0.099 0.068 0.025 0.136 0.057 0.203 0.083 0.105 0.048 0.209 0.1 0.313 0.152l0.14 0.067c0.104 0.053 0.204 0.109 0.303 0.167 0.063 0.037 0.125 0.073 0.187 0.115 1.111 0.688 2.037 1.641 2.683 2.776-0.817-0.572-2.287-1.145-3.697-0.895 5.52 2.76 4.036 12.265-3.615 11.905-0.683-0.025-1.355-0.156-1.995-0.385-0.156-0.057-0.308-0.12-0.453-0.183-0.088-0.041-0.177-0.083-0.26-0.124-1.876-0.969-3.423-2.803-3.615-5.027 0 0 0.708-2.64 5.072-2.64 0.475 0 1.824-1.319 1.849-1.699-0.011-0.125-2.683-1.187-3.724-2.213-0.557-0.547-0.817-0.812-1.052-1.011-0.125-0.109-0.26-0.208-0.401-0.301-0.348-1.224-0.364-2.521-0.041-3.751-1.579 0.719-2.803 1.855-3.693 2.855h-0.009c-0.609-0.771-0.563-3.313-0.532-3.844-0.005-0.036-0.453 0.229-0.511 0.271-0.536 0.385-1.041 0.813-1.5 1.287-0.525 0.531-1.004 1.104-1.437 1.719-0.984 1.396-1.687 2.979-2.057 4.645-0.005 0.021-0.145 0.647-0.249 1.417-0.021 0.12-0.037 0.24-0.052 0.359-0.043 0.292-0.073 0.589-0.089 0.881l-0.005 0.047c-0.009 0.172-0.020 0.339-0.031 0.511v0.077c0 8.48 6.875 15.355 15.355 15.355 7.593 0 13.9-5.516 15.135-12.756 0.027-0.197 0.047-0.395 0.068-0.593 0.307-2.631-0.031-5.401-0.995-7.713z"/></svg>') !important;
	width: 16px !important;
	height: 16px !important;
}

.tabbrowser-tab[selected] .tab-icon-image[src="chrome://branding/content/icon32.png"] {
	fill: var(--accent-color) !important;
}

/* Change icon of new private tab and private window indication */
.tab-icon-image[src="chrome://browser/skin/privatebrowsing/favicon.svg"],
.private-browsing-indicator-icon {
	-moz-context-properties: fill !important;
	fill: var(--fg-color) !important;
	content: url('data:image/svg+xml;utf8,<svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"><path fill="context-fill" fill-rule="evenodd" d="M13.948 5.886c-1.143-1.501-3.388-1.693-4.785-.409l-.782.718-.765 0-.782-.718c-1.398-1.284-3.642-1.092-4.786.409-.148.585.081 2.745.21 3.085.26 1.372 1.382 2.404 2.726 2.404.671 0 1.279-.268 1.76-.697l.293-.251a1.451 1.451 0 0 1 1.883-.016l.44.364 0-.002a2.622 2.622 0 0 0 1.652.601c1.344 0 2.466-1.032 2.726-2.404.13-.339.367-2.49.21-3.084z M5.3 6.843c-.558 0-1.054.233-1.374.594a.519.519 0 0 0 0 .678c.32.362.816.594 1.374.594s1.054-.233 1.374-.594a.519.519 0 0 0 0-.678A1.828 1.828 0 0 0 5.3 6.843z M10.7 6.843c-.558 0-1.054.233-1.374.594a.519.519 0 0 0 0 .678c.32.362.816.594 1.374.594s1.054-.233 1.374-.594a.519.519 0 0 0 0-.678 1.828 1.828 0 0 0-1.374-.594z" /></svg>') !important;
	width: 24px !important;
	height: 24px !important;
}

.tabbrowser-tab[selected] .tab-icon-image[src="chrome://browser/skin/privatebrowsing/favicon.svg"] {
	fill: var(--accent-color) !important;
}

.private-browsing-indicator-icon {
	margin-block-end: -1px !important;
}

/* Change color of "Private browsing" text */
.private-browsing-indicator-label {
	color: var(--fg-color) !important;
}

/* Change icon of directory navigation */
.tab-icon-image[src="data:image/png;base64,"] {
	-moz-context-properties: fill !important;
	fill: var(--fg-color) !important;
	content: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg"><path d="M426.666667 170.666667H170.666667c-47.146667 0-84.906667 38.186667-84.906667 85.333333L85.333333 768c0 47.146667 38.186667 85.333333 85.333334 85.333333h682.666666c47.146667 0 85.333333-38.186667 85.333334-85.333333V341.333333c0-47.146667-38.186667-85.333333-85.333334-85.333333H512l-85.333333-85.333333z" /></svg>') !important;
	width: 16px !important;
	height: 16px !important;
}

.tabbrowser-tab[selected] .tab-icon-image[src="data:image/png;base64,"] {
	fill: var(--accent-color) !important;
}

/* Change icon of Discord tab */
.tabbrowser-tab[data-site="discord"] .tab-icon-image {
	-moz-context-properties: fill !important;
	fill: var(--fg-color) !important;
	content: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 -28.5 256 256" xmlns="http://www.w3.org/2000/svg"><path d="M216.856339,16.5966031 C200.285002,8.84328665 182.566144,3.2084988 164.041564,0 C161.766523,4.11318106 159.108624,9.64549908 157.276099,14.0464379 C137.583995,11.0849896 118.072967,11.0849896 98.7430163,14.0464379 C96.9108417,9.64549908 94.1925838,4.11318106 91.8971895,0 C73.3526068,3.2084988 55.6133949,8.86399117 39.0420583,16.6376612 C5.61752293,67.146514 -3.4433191,116.400813 1.08711069,164.955721 C23.2560196,181.510915 44.7403634,191.567697 65.8621325,198.148576 C71.0772151,190.971126 75.7283628,183.341335 79.7352139,175.300261 C72.104019,172.400575 64.7949724,168.822202 57.8887866,164.667963 C59.7209612,163.310589 61.5131304,161.891452 63.2445898,160.431257 C105.36741,180.133187 151.134928,180.133187 192.754523,160.431257 C194.506336,161.891452 196.298154,163.310589 198.110326,164.667963 C191.183787,168.842556 183.854737,172.420929 176.223542,175.320965 C180.230393,183.341335 184.861538,190.991831 190.096624,198.16893 C211.238746,191.588051 232.743023,181.531619 254.911949,164.955721 C260.227747,108.668201 245.831087,59.8662432 216.856339,16.5966031 Z M85.4738752,135.09489 C72.8290281,135.09489 62.4592217,123.290155 62.4592217,108.914901 C62.4592217,94.5396472 72.607595,82.7145587 85.4738752,82.7145587 C98.3405064,82.7145587 108.709962,94.5189427 108.488529,108.914901 C108.508531,123.290155 98.3405064,135.09489 85.4738752,135.09489 Z M170.525237,135.09489 C157.88039,135.09489 147.510584,123.290155 147.510584,108.914901 C147.510584,94.5396472 157.658606,82.7145587 170.525237,82.7145587 C183.391518,82.7145587 193.761324,94.5189427 193.539891,108.914901 C193.539891,123.290155 183.391518,135.09489 170.525237,135.09489 Z" fill-rule="nonzero" /></svg>') !important;
	width: 16px !important;
	height: 16px !important;
}

.tabbrowser-tab[data-site="discord"][selected] .tab-icon-image {
	fill: var(--accent-color) !important;
}

/* Change icon of Gmail tab */
.tabbrowser-tab[data-site="gmail"] .tab-icon-image {
	-moz-context-properties: fill !important;
	fill: var(--fg-color) !important;
	content: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 24 24" version="1.1" xmlns="http://www.w3.org/2000/svg"><path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z" /></svg>') !important;
	width: 16px !important;
	height: 16px !important;
}

.tabbrowser-tab[data-site="gmail"][selected] .tab-icon-image {
	fill: var(--accent-color) !important;
}

/* Change icon of YouTube tab */
.tabbrowser-tab[data-site="youtube"] .tab-icon-image {
	-moz-context-properties: fill !important;
	fill: var(--fg-color) !important;
	content: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 28.57 20" version="1.1" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M27.9727 3.12324C27.6435 1.89323 26.6768 0.926623 25.4468 0.597366C23.2197 0 14.285 0 14.285 0C14.285 0 5.35042 0 3.12323 0.597366C1.89323 0.926623 0.926623 1.89323 0.597366 3.12324C0 5.35042 0 10 0 10C0 10 0 14.6496 0.597366 16.8768C0.926623 18.1068 1.89323 19.0734 3.12323 19.4026C5.35042 20 14.285 20 14.285 20C14.285 20 23.2197 20 25.4468 19.4026C26.6768 19.0734 27.6435 18.1068 27.9727 16.8768C28.5701 14.6496 28.5701 10 28.5701 10C28.5701 10 28.5677 5.35042 27.9727 3.12324Z M11.4253 14.2854L18.8477 10.0004L11.4253 5.71533Z" /></svg>') !important;
	width: 17px !important;
	height: 17px !important;
}

.tabbrowser-tab[data-site="youtube"][selected] .tab-icon-image {
	fill: var(--accent-color) !important;
}

/* Change icon of Canvas tab */
.tabbrowser-tab[data-site="canvas"] .tab-icon-image {
	-moz-context-properties: fill !important;
	fill: var(--fg-color) !important;
	content: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="-13.5 -19.5 74 74" version="1.1" xmlns="http://www.w3.org/2000/svg"><circle cx="22.5" cy="15.5" r="33.5" fill="none" stroke="context-fill" stroke-width="4" /><g><path d="m19.499 20.4730468c0 7.9926634-3.3054071 10.5289532-9.51827314 10.5289532-7.11840136 0-9.48172686-3.5374034-9.48172686-10.908686v-20.091314h4.68401368v19.7257959c0 2.6926503-.17664031 7.7550766 4.83222912 7.7550766 4.13785 0 4.8789271-3.007402 4.8789271-7.545919v-19.9349535h4.6048301z" /><path d="m34.3858108 3.70546667v27.29653333h-4.7736216v-27.29653333h-7.1131892v-3.70346667h19v3.70346667z" /><circle cx="42" cy="28.5" r="3.3" /></g></svg>') !important;
	width: 20px !important;
	height: 20px !important;
}

.tabbrowser-tab[data-site="canvas"][selected] .tab-icon-image {
	fill: var(--accent-color) !important;
}

/* Change icon of Github tab */
.tabbrowser-tab[data-site="github"] .tab-icon-image {
	-moz-context-properties: fill !important;
	fill: var(--fg-color) !important;
	content: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 24 24" version="1.1" xmlns="http://www.w3.org/2000/svg"><path d="M12,2A10,10,0,0,0,8.84,21.5c.5.08.66-.23.66-.5V19.31C6.73,19.91,6.14,18,6.14,18A2.69,2.69,0,0,0,5,16.5c-.91-.62.07-.6.07-.6a2.1,2.1,0,0,1,1.53,1,2.15,2.15,0,0,0,2.91.83,2.16,2.16,0,0,1,.63-1.34C8,16.17,5.62,15.31,5.62,11.5a3.87,3.87,0,0,1,1-2.71,3.58,3.58,0,0,1,.1-2.64s.84-.27,2.75,1a9.63,9.63,0,0,1,5,0c1.91-1.29,2.75-1,2.75-1a3.58,3.58,0,0,1,.1,2.64,3.87,3.87,0,0,1,1,2.71c0,3.82-2.34,4.66-4.57,4.91a2.39,2.39,0,0,1,.69,1.85V21c0,.27.16.59.67.5A10,10,0,0,0,12,2Z" /></svg>') !important;
	width: 19px !important;
	height: 19px !important;
}

.tabbrowser-tab[data-site="github"][selected] .tab-icon-image {
	fill: var(--accent-color) !important;
}

/* Add more space between tab icon and label */
.tab-icon-image, .tab-throbber {
	margin-inline-end: 8px !important;
}

/* Improve tab icon vertical alignment */
.tab-icon-image:not([src="chrome://branding/content/icon32.png"]),
button#main-button[aria-label="Mute tab"] {
	margin-block-end: -1px !important;
}

/* Hide tab close button */
.tab-close-button {
	display: none !important;
}

/* Hide new tab button */
/*
toolbarbutton#new-tab-button {
	display: none !important;
}

toolbarbutton#tabs-newtab-button {
	display: none !important;
}
*/

/* _Or_ customize new tab button */
toolbarbutton#new-tab-button:active {
	fill: var(--accent-color) !important;
}

toolbarbutton#tabs-newtab-button:active {
	fill: var(--accent-color) !important;
}

/* Toolbar background */
#nav-bar,
#TabsToolbar {
	background: var(--bg-color) !important;
	border: none !important;
	box-shadow: none !important;
}

/* URL bar background (including search suggestions) */
.urlbar-background {
	background: var(--bg-color) !important;
	border: none !important;
	outline: none !important;
}

#urlbar[focused] > .urlbar-background {
	background: var(--lighter-bg-color) !important;
}

.urlbarView-body-inner {
	border-top: 2px solid var(--accent-color) !important;
}

.urlbarView-url {
	color: var(--fg-color) !important;
}

#urlbar-input {
	font-weight: bold !important;
	padding-left: 5px !important;
	padding-right: 0px !important;
}

/* Tab preview */
.tab-preview-content-main {
	background: var(--lighter-bg-color) !important;
	border: 1px solid var(--bg-color) !important;
}

.tab-preview-thumbnail-container {
	& > canvas{
		border: 1px solid var(--bg-color) !important;
	}
}

/* Center tab content */
.tab-icon-stack {
	margin-inline-start: auto
}

.tab-label-container {
	max-width: min-content;
	margin-inline-end: auto;
}

/* Increase minimum tab width */
.tabbrowser-tab {
	min-width: 125px !important;
}

/* Change tab decorations */
.tab-background {
	background: transparent !important;
	border: none !important;
	box-shadow: none !important;
	border-radius: 4px !important;
}

.tab-label {
	color: var(--fg-color) !important;
	font-weight: 500 !important;
}

/* Selected tab decorations */
.tabbrowser-tab[selected] .tab-background {
	background: transparent !important;
	border: 1.5px solid var(--accent-color) !important;
	box-shadow: none !important;
	border-radius: 5px !important;
}

.tabbrowser-tab[selected] .tab-label {
	color: var(--accent-color) !important;
	font-weight: 700 !important;
}

/* Dimmed urlbar scheme */
.urlbar-input .text-link{
	color: #ff0000 !important;
}

.urlbar-input-box .urlbar-scheme {
	color: #ff0000 !important;
	font-weight: 400 !important;
}

/* Normal color for real/host part of URL */
.urlbar-input-box .urlbar-domain {
	color: #e8e8e8 !important;
	font-weight: 700 !important;
}

/* Placeholder text */
#urlbar-input::placeholder {
	color: #a5a3a1 !important;
	font-weight: 700 !important;
}

/** End customize address bar **/

/** Customize tab right-click popup menu **/

/* Hide new tab to right button */
menuitem#context_openANewTab {
	display: none !important;
}

/* Hide move tab menu */
menu#context_moveTabOptions {
	display: none !important;
}

/* Hide share tab button */
menu.share-tab-url-item {
	display: none !important;
}

/* Hide add tab to new group button */
menuitem#context_moveTabToNewGroup {
	display: none !important;
}

/* Hide add split view button */
menuitem#context_moveTabToSplitView {
	display: none !important;
}

/* Hide close duplicate tabs button */
menuitem#context_closeDuplicateTabs {
	display: none !important;
}

/* Hide close multiple tabs menu */
menu#context_closeTabOptions {
	display: none !important;
}

/* Hide send to mobile menu */
menu#context_sendTabToDevice {
	display: none !important;
}

/* Hide separators */
menupopup#tabContextMenu menuseparator {
	display: none !important;
}

/** End customize tab right-click popup menu **/

/** Customize burger menu **/

/* Hide sync button */
toolbaritem#appMenu-fxa-status2 {
	display: none !important;
}

/* Hide profiles button */
toolbarbutton#appMenu-empty-profiles-button {
	display: none !important;
}

/* Hide ugly gradient separator */
toolbarseparator#appMenu-fxa-separator {
	display: none !important;
}

/* Other separators are not uniquely identified unfortunately */
toolbarseparator {
	display: none !important;
}

/* Hide print button (just use hotkey) */
toolbarbutton#appMenu-print-button2 {
	display: none !important;
}

/* Hide save button (just use hotkey) */
toolbarbutton#appMenu-save-file-button2 {
	display: none !important;
}

/* Hide find button (just use hotkey) */
toolbarbutton#appMenu-find-button2 {
	display: none !important;
}

/* Hide zoom controls (just use hotkeys) */
toolbaritem#appMenu-zoom-controls {
	display: none !important;
}

/* Hide report broken site button */
toolbarbutton#appMenu-report-broken-site-button {
	display: none !important;
}

/* Hide help button */
toolbarbutton#appMenu-help-button2 {
	display: none !important;
}

/* Hide quit button */
toolbarbutton#appMenu-quit-button2 {
	display: none !important;
}

/** End customize burger menu **/

/** Customize (right-click) popup **/

/* Hide useless menu navigation group */
menugroup#context-navigation {
	display: none !important;
}

/* Hide useless select all */
menuitem#context-selectall {
	display: none !important;
}

/* Hide "Inspect Accessibility Properties */
menuitem#context-inspect-a11y {
	display: none !important;
}

/* Hide take screenshot button */
menuitem#context-take-screenshot {
	display: none !important;
}

/* Hide email image button (be fr bruv) */
menuitem#context-sendimage {
	display: none !important;
}

/* Hide send to mobile menu */
menu#context-sendpagetodevice {
	display: none !important;
}

/* Hide bookmark link button */
menuitem#context-bookmarklink {
	display: none !important;
}

/* Hide save link as button */
menuitem#context-savelink {
	display: none !important;
}

/* Hide open link in split view button */
menuitem#context-openlinkinsplitview {
	display: none !important;
}

/* Hide separators */
menuseparator#context-sep-screenshots,
menuseparator#context-sep-selectall,
menuseparator#context-sep-sendpagetodevice,
menuseparator#context-sep-navigation {
	display: none !important;
}

menupopup#contentAreaContextMenu menuitem:hover {
	background-color: var(--accent-color) !important;
}

menu[_moz-menuactive="true"] {
	background-color: var(--accent-color) !important;
}

/** End customize popup **/

/* Style history sidebar */
#sidebar-box,
#historyTree {
	background-color: var(--bg-color) !important;
	color: var(--fg-color) !important;
}

#search-box {
	--input-text-background-color: var(--lighter-bg-color) !important;
	--input-text-border-color: var(--accent-color) !important;
}

#input {
	outline: none !important;
	padding-right: 0 !important;
}

#viewButton {
	background-color: var(--lighter-bg-color) !important;
	color: var(--fg-color) !important;
	border-color: var(--accent-color) !important;
	border-radius: 8px !important;
	padding: 5px !important;
	margin-top: 0 !important;
	margin-bottom: 0 !important;
}

toolbarbutton#sidebar-close {
	background: none !important;
	outline: none !important;
	border: none !important;
}

toolbarbutton#sidebar-close:active {
	outline: 1px solid var(--accent-color) !important;
	fill: var(--accent-color) !important;
}

/* Style print popup */
:root[dialogroot] {
	--background-color-canvas: var(--bg-color) !important;
}

/** Customize CTRL + F find bar **/

/* Customize entire element */
findbar {
	position: absolute !important;
	top: 12px !important;
	right: 20px !important;
	padding: 16px 6px !important;
	min-width: 400px !important;
	contain: none !important;

	background: none !important;
	background-color: var(--lighter-bg-color) !important;
	color: var(--fg-color) !important;

	border: 1px solid var(--bg-color) !important;
	border-radius: 6px !important;
	box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4) !important;
}

/* Customize text input */
.findbar-textbox {
	order: 1 !important;
	width: 200px !important;
	padding: 0 8px !important;
	margin-right: 6px !important;

	background: transparent !important;
	color: var(--fg-color) !important;

	border: none !important;
	outline: none !important;
}

/* Change color when pattern is not found */
.findbar-textbox[status="notfound"] {
	background-color: rgba(255, 60, 60, 0.15) !important;
	color: #ff9999 !important;
	border-radius: 4px !important;
}

/* Customize status text */
.findbar-find-status,
.findbar-label {
	margin: 0 6px !important;

	font-weight: normal !important;
	font-style: italic !important;
}

/* Style buttons */
toolbarbutton.findbar-find-previous,
toolbarbutton.findbar-find-next,
toolbarbutton.findbar-closebutton {
	padding: 6px !important;
	margin: 0 2px !important;

	fill: var(--fg-color) !important;
	cursor: pointer !important;
}

toolbarbutton.findbar-find-previous:active,
toolbarbutton.findbar-find-next:active,
toolbarbutton.findbar-closebutton:active {
	fill: var(--accent-color) !important;
}

/* Change order of buttons */
toolbarbutton.findbar-find-previous {
	order: 3 !important;

	border-left: 1px solid #3E3E42 !important;
	border-radius: 0 !important;
	padding-left: 10px !important;
}

toolbarbutton.findbar-find-next {
	order: 4 !important;
}

toolbarbutton.findbar-closebutton {
	order: 99 !important;
	margin-right: 6px !important;
}

/* Hide advanced controls */
.findbar-highlight,
.findbar-case-sensitive,
.findbar-match-diacritics,
.findbar-entire-word {
	display: none !important;
}

/** End customize CTRL + F find bar **/

/* Style URL/status text in the bottom-left corner */
#statuspanel-label {
	padding: 3px !important;

	background-color: var(--lighter-bg-color) !important;
	color: var(--fg-color) !important;

	border: none !important;
	border-top: 2px solid var(--accent-color) !important;
	border-right: 2px solid var(--accent-color) !important;
	border-radius: 0 !important;
}

/* Change color of tab load animation */
.tab-loading-burst {
	--tab-loading-fill: var(--accent-color) !important;
}

/** Customize download popup **/
dialog#unknownContentType {
	background-color: var(--bg-color) !important;
	color: var(--fg-color) !important;
}

/* Customize "Open with" dropdown */
menulist#openHandler {
	appearance: none !important;

	background-color: var(--lighter-bg-color) !important;
	color: var(--fg-color) !important;
	border: 2px solid var(--accent-color) !important;
	border-radius: 4px !important;
	padding: 3px !important;
}

/* Style buttons */
button[part="dialog-button"] {
	appearance: none !important;

	border-radius: 8px !important;
	padding: 8px 16px !important;
	margin-bottom: 10px !important;
}

button[part="dialog-button"]:not([dlgtype="accept"]) {
	background-color: var(--lightest-bg-color) !important;
	border: none !important;
}

button[dlgtype="accept"] {
	border: 2px solid var(--accent-color) !important;
}

/* Customize radio inputs */
#unknownContentType .radio-check {
	appearance: none !important;

	width: 16px !important;
	height: 16px !important;

	margin-right: 6px !important;
	margin-block-end: -1px !important;

	background-color: var(--lightest-bg-color) !important;
	border-radius: 50% !important;
	border: none !important;
	outline: none !important;
}

#unknownContentType radio[selected="true"] .radio-check {
	background-color: var(--accent-color) !important;
}

/* Customize unchecked checkbox */
checkbox#rememberChoice:not([checked]) .checkbox-check {
	appearance: none !important;
	background-color: var(--lightest-bg-color) !important;
	border-radius: 3px !important;
}

/** End customize download popup **/

}

